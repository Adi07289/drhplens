# Secrets — never commit
.env
.env.*
!.env.example

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environments
.venv/
venv/
env/

# Test / lint / type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Build artifacts
dist/
build/
*.egg-info/

# ML experiment tracking
mlruns/

# Docling model cache (large weights; downloaded on first run)
# ~/.cache/docling/ is user-level; if cached inside the project:
.cache/docling/

# macOS metadata
.DS_Store

# Editor junk
.idea/
.vscode/
*.swp
*.swo

# Jupyter
.ipynb_checkpoints/

# NOTE: data/swiggy_drhp/*.pdf is intentionally NOT ignored.
# The DRHP binary is committed for reproducibility + SHA-pin integrity.
# See data/swiggy_drhp/SHA256SUMS and tests/unit/test_drhp_integrity.py.

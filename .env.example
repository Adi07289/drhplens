# DRHPLens — environment variable template
# Copy to .env and fill in your own values.
# NEVER commit .env with real values — only commit this .env.example.
# On HF Spaces, add these via the Spaces secrets UI (not as files).

# Gemini API key (free tier: 1500 req/day — https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Groq API key — LLM fallback (free tier — https://console.groq.com/keys)
GROQ_API_KEY=

# Qdrant Cloud cluster URL and API key
# Free 1GB cluster at https://cloud.qdrant.io/
QDRANT_URL=
QDRANT_API_KEY=

# Langfuse observability (free cloud tier — https://cloud.langfuse.com)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional: override to self-hosted instance
# LANGFUSE_HOST=https://cloud.langfuse.com
